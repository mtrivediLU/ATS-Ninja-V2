# ATS-Ninja-V2 root environment example.
# Copy to .env for local overrides; NEVER commit a real .env.
# Per-app examples: apps/api/.env.example, apps/web/.env.example.

# --- Engine (ats_engine) ---------------------------------------------------
# Ollama is optional; without it the engine runs a fully deterministic path.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Content-hash cache for parsed profiles / LLM generations.
# ATS_ENGINE_LLM_CACHE=1
# ATS_ENGINE_LLM_CACHE_DIR=~/.cache/ats-engine/llm
# ATS_ENGINE_LLM_CACHE_TTL=604800
# ATS_ENGINE_LLM_TIMEOUT=120

# --- API (apps/api) --------------------------------------------------------
# ATS_API_ENVIRONMENT=development
# ATS_API_CORS_ORIGINS=["http://localhost:3000"]

# --- Web (apps/web) --------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000
