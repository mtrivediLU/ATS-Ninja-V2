# ATS-Ninja-V2 API environment (copy to .env; never commit real secrets)
# Defaults are safe for local dev; the compose topology sets these per service.

# ATS_API_ENVIRONMENT=development
# ATS_API_API_V1_PREFIX=/api/v1
# ATS_API_CORS_ORIGINS=["http://localhost:3000"]

# Persistence (async SQLAlchemy). Compose overrides host to `db`.
# ATS_API_DATABASE_URL=postgresql+asyncpg://ats:ats@localhost:5432/ats_ninja
# ATS_API_DATABASE_ECHO=false

# Async job queue broker (arq over Redis). Compose overrides host to `redis`.
# ATS_API_REDIS_URL=redis://localhost:6379
# ATS_API_WORKER_MAX_JOBS=4

# When true, the engine auto-detects a local LLM (Ollama) and falls back to the
# deterministic path. Set false to force fully deterministic generation.
# ATS_API_ENGINE_USE_LLM=true

# Engine settings (consumed by ats-engine via the environment)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# ATS_ENGINE_LLM_CACHE=1
