{
  "$schema": "https://design-tokens.org/format",
  "meta": {
    "product": "ATS-Ninja-V2",
    "phase": "D0 — UI/UX Foundation",
    "direction": "Signal — calm modern workspace",
    "note": "Foundational tokens only. Light theme is authoritative; dark theme is a recommendation, not approved for build. Values mirror design-tokens.css."
  },
  "color": {
    "primitive": {
      "paper": "#faf9f6",
      "white": "#ffffff",
      "ink": {
        "900": "#1c1c1a",
        "700": "#45423b",
        "600": "#57544d",
        "500": "#6f6c62",
        "400": "#8a877c",
        "300": "#a8a496"
      },
      "primary": {
        "50": "#eef4f1",
        "100": "#e8f0ea",
        "200": "#cadfd2",
        "300": "#9cc3ac",
        "500": "#3a7d62",
        "600": "#2f6b52",
        "700": "#245140",
        "800": "#1c3f32"
      }
    },
    "surface": {
      "canvas": "#faf9f6",
      "default": "#ffffff",
      "subtle": "#f4f2ec",
      "raised": "#f1efe8"
    },
    "border": {
      "subtle": "#eeece5",
      "default": "#e7e4dc",
      "strong": "#d8d4c8"
    },
    "text": {
      "primary": "#1c1c1a",
      "secondary": "#57544d",
      "muted": "#8a877c",
      "faint": "#a8a496",
      "onAccent": "#ffffff",
      "link": "#2f6b52",
      "linkHover": "#245140"
    },
    "accent": {
      "base": "#2f6b52",
      "hover": "#245140",
      "active": "#1c3f32",
      "subtleBg": "#e8f0ea",
      "subtleBorder": "#cadfd2"
    },
    "status": {
      "positive": { "fg": "#2f6b52", "bg": "#e8f0ea", "border": "#cadfd2", "meaning": "supported claim · completed kit · strong fit" },
      "warning":  { "fg": "#8a5a12", "bg": "#f6edda", "border": "#ecdcb4", "meaning": "repaired claim · partial fit" },
      "danger":   { "fg": "#a3301c", "bg": "#f7e6e2", "border": "#eec7bd", "meaning": "rejected/withheld claim · failed kit · must-have gap" },
      "info":     { "fg": "#2b52a3", "bg": "#e7edf8", "border": "#c8d5ee", "meaning": "processing · in-progress" },
      "neutral":  { "fg": "#57544d", "bg": "#f1efe8", "border": "#e0ddd3", "meaning": "pending · absent · not requested" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "\"Hanken Grotesk\", ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
      "mono": "\"IBM Plex Mono\", ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.8125rem",
      "base": "0.9375rem",
      "md": "1.0625rem",
      "lg": "1.25rem",
      "xl": "1.5rem",
      "2xl": "2rem"
    },
    "lineHeight": { "tight": 1.2, "normal": 1.5, "relaxed": 1.65 },
    "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "letterSpacing": { "overline": "0.06em" },
    "scale": [
      { "token": "display", "size": "2rem", "weight": 700, "leading": 1.2, "use": "empty-state headline, marketing" },
      { "token": "title-page", "size": "1.5rem", "weight": 700, "leading": 1.2, "use": "page titles" },
      { "token": "title-panel", "size": "1.25rem", "weight": 600, "leading": 1.2, "use": "workspace / panel titles" },
      { "token": "subtitle", "size": "1.0625rem", "weight": 600, "leading": 1.3, "use": "section subtitles" },
      { "token": "body", "size": "0.9375rem", "weight": 400, "leading": 1.5, "use": "default UI text" },
      { "token": "body-sm", "size": "0.8125rem", "weight": 400, "leading": 1.5, "use": "secondary UI text" },
      { "token": "caption", "size": "0.75rem", "weight": 400, "leading": 1.4, "use": "captions, meta" },
      { "token": "mono", "size": "0.75rem", "weight": 500, "leading": 1.4, "use": "kit IDs, evidence locators, scores" },
      { "token": "overline", "size": "0.6875rem", "weight": 600, "leading": 1.2, "tracking": "0.06em", "transform": "uppercase", "use": "nav group labels, panel eyebrows" }
    ]
  },
  "spacing": {
    "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px"
  },
  "radius": {
    "sm": "6px", "md": "8px", "control": "7px", "lg": "12px", "xl": "16px", "pill": "999px"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(28,28,26,0.05)",
    "sm": "0 1px 3px rgba(28,28,26,0.08)",
    "md": "0 4px 14px rgba(28,28,26,0.09)",
    "lg": "0 14px 36px rgba(28,28,26,0.14)"
  },
  "layout": {
    "sidebarWidth": "248px",
    "sidebarCollapsedWidth": "64px",
    "evidencePanelWidth": "360px",
    "headerHeight": "60px",
    "bottomNavHeight": "60px",
    "contentMaxWidth": "1200px",
    "grid": { "columns": 12, "gutter": "24px", "margin": "24px" }
  },
  "focus": {
    "ringColor": "#2f6b52",
    "ringWidth": "2px",
    "ringOffset": "2px"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "180ms", "slow": "240ms" },
    "easing": { "out": "cubic-bezier(0.2,0.8,0.2,1)", "inOut": "cubic-bezier(0.4,0,0.2,1)" },
    "reducedMotion": "All non-essential motion is disabled under prefers-reduced-motion: reduce."
  },
  "zIndex": {
    "header": 100, "overlay": 190, "drawer": 200, "dialog": 300, "toast": 400, "tooltip": 500
  },
  "breakpoints": {
    "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px",
    "behavior": {
      "mobile": "<768px — hamburger nav drawer + bottom tab bar; evidence as full-height sheet; single column",
      "tablet": "768–1023px — collapsed 64px icon rail; evidence as overlay drawer; single content column",
      "desktop": "1024–1279px — full 248px sidebar; evidence as toggleable inline panel",
      "wide": ">=1280px — full sidebar; evidence panel can stay persistent alongside content"
    }
  }
}
